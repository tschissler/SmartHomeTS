FROM mcr.microsoft.com/dotnet/sdk:10.0 AS build
WORKDIR /src
COPY BMWConnector/BMWConnector.csproj BMWConnector/
RUN dotnet restore BMWConnector/BMWConnector.csproj
COPY . .
RUN dotnet publish BMWConnector/BMWConnector.csproj -c Release -o /app/publish

FROM mcr.microsoft.com/dotnet/aspnet:10.0
WORKDIR /app
COPY --from=build /app/publish .

ENTRYPOINT ["dotnet", "BMWConnector.dll"]
